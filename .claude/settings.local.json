{
  "verbose": true,
  "outputStyle": "detailed",
  "permissions": {
    "allow": [
      "Bash(git -C /Users/kimhyeongju/personal-info-check-app status)",
      "Bash(git init *)",
      "Bash(git config *)",
      "Bash(npm install *)",
      "Bash(npm *)",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "사용자가 파일을 수정했습니다. 이 변경사항에 대해 간단하고 명확한 설명을 1-2문장으로 제공해주세요. 왜 이렇게 변경했는지, 이것이 어떤 역할을 하는지 설명해주세요.",
            "statusMessage": "변경사항 설명 생성 중...",
            "continueOnBlock": true
          }
        ]
      }
    ]
  }
}
